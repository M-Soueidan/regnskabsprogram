# PWA: korrekt MIME til web app manifest
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

# Hostinger / Apache: send alle ruter til index.html (React Router SPA)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
